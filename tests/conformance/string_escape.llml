;; String escape sequences
;; Tests: backslash escape sequences in string literals are recognized by the lexer
;; Note: the lexer accepts escape sequences in the grammar but stores them as raw characters
;; This test documents the current behavior of string literals containing backslash sequences
(do
  ($print "hello \"world\"")
  ($print "she said \"hi\"")
  ($print "backslash: \\")
  ($print "tab:\there"))
